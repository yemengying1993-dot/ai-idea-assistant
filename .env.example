# 飞书配置（必填）
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_VERIFY_TOKEN=your_feishu_verify_token  # 飞书事件订阅 → 验证令牌

# Claude API（可选，用于 AI 分类）
ANTHROPIC_API_KEY=sk-ant-xxxxx

# 企业微信配置（可选）
WEWORK_TOKEN=
WEWORK_ENCODING_AES_KEY=
WEWORK_CORP_ID=

# 存储模式（可选，默认 feishu）
# feishu: 仅存飞书云文档
# obsidian: 仅存 Obsidian vault
# both: 同时存两者
STORAGE_MODE=feishu

# Obsidian 配置（STORAGE_MODE 为 obsidian 或 both 时需要）
OBSIDIAN_REPO_URL=https://github.com/yourname/obsidian-vault.git
OBSIDIAN_VAULT_PATH=obsidian_vault
OBSIDIAN_NOTES_SUBDIR=Ideas

# 服务端口（可选，默认 5001）
PORT=5001

# 飞书配置（必填）
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=your_feishu_app_secret
FEISHU_VERIFY_TOKEN=your_feishu_verify_token  # 飞书事件订阅 → 验证令牌

# Claude API（可选，用于 AI 分类）
ANTHROPIC_API_KEY=sk-ant-xxxxx

# 企业微信配置（可选）
WEWORK_TOKEN=
WEWORK_ENCODING_AES_KEY=
WEWORK_CORP_ID=

# 存储模式（可选，默认 feishu）
# feishu: 仅存飞书云文档
# obsidian: 仅存 Obsidian vault
# both: 同时存两者
STORAGE_MODE=feishu

# Obsidian 配置（STORAGE_MODE 为 obsidian 或 both 时需要）
OBSIDIAN_GITHUB_TOKEN=ghp_xxxxxxxxxxxx       # GitHub Personal Access Token（需要 repo 权限）
OBSIDIAN_GITHUB_REPO=luckylucky-ai/obsidian  # 仓库名，格式：owner/repo
OBSIDIAN_NOTES_SUBDIR=第二大脑               # vault 内的笔记目录

# 服务端口（可选，默认 5001）
PORT=5001
